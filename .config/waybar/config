{
  "layer": "top",
  "position": "top",
  "height": 0,
  "spacing": 0,
  "margin-top": 0,
  "margin-bottom": 0,
  "margin-left": 5,
  "margin-right": 10,

  "modules-left":   ["sway/workspaces"],
  "modules-center": ["mpris"],
  "modules-right":  [
    "sway/language",
    "network",
    "cpu",
    "pulseaudio",
    "tray",
    "clock"
  ],

  // в”Җв”Җ workspaces в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
  "sway/workspaces": {
    "disable-scroll": true,
    "all-outputs": false,
    "tooltip": false
  },

  // в”Җв”Җ language в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
  "sway/language": {
    "format":   "вҢЁ {}",
    "tooltip":  false,
    "on-click": "swaymsg input type:keyboard xkb_switch_layout next"
  },

  // в”Җв”Җ media в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
  "mpris": {
    "format":        "{player_icon} {title} вҖ” {artist}",
    "format-paused": " {title} вҖ” {artist}",
    "max-length":    40,
    "tooltip":       false,
    "player-icons": {
      "default": "в–¶",
      "spotify": "пҶј",
      "firefox": "у°Ҳ№",
      "mpv":     "пҚ®",
      "spotube": "уұҚҡ "
    },
    "status-icons": {
      "paused": "пҒҢ"
    }
  },

  // в”Җв”Җ network в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
  "network": {
    "interface":           "wlp0s20f3",
    "format-wifi":         "пҮ«  {bandwidthDownBits}",
    "format-ethernet":     "пҮ«  {bandwidthDownBits}",
    "format-disconnected": "у°Ө®  offline",
    "format-linked":       "у°Ө«  no ip",
    "interval":            5,
    "tooltip":             false,
    "on-click":            "foot nmtui"
  },

  // в”Җв”Җ cpu в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
  "cpu": {
    "format":   "у°ҳҡ {usage}%",
    "interval": 2,
    "tooltip":  false,
    "on-click": "foot btop"
  },

  // в”Җв”Җ audio в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
  "pulseaudio": {
    "format":           "{icon} {volume}%",
    "format-muted":     "у°қҹ muted",
    "format-bluetooth": "у°ӮҜ {volume}%",
    "format-icons": {
      "default":          ["у°•ҝ", "у°–Җ", "у°•ҫ"],
      "headphone":        "у°ӢӢ",
      "headset":          "у°ӢҺ",
      "hands-free":       "у°ӢҺ",
      "portable":         "у°„қ"
    },
    "scroll-step":  5,
    "max-volume":   150,
    "on-click":     "pavucontrol",
    "tooltip":      false
  },

  // в”Җв”Җ tray в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
  "tray": {
    "spacing": 10,
    "tooltip": false
  },

  // в”Җв”Җ clock в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
  "clock": {
    "format":          "у°…җ {:%H:%M}",
    "format-alt":      "у°ғӯ {:%a %d.%m.%Y}",
    "tooltip":         false,
    "on-click-middle": "kitty calcurse"
  }
}
